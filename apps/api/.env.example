NODE_ENV=production
PORT=4010
API_PREFIX=api

# MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/gde_tort
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/gde_tort?retryWrites=true&w=majority

# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_RANDOM_STRING

JWT_EXPIRES_IN=8h

# Your Vercel frontend URL (comma-separated for multiple)
WEB_ORIGIN=https://your-app.vercel.app

# First-run admin seed
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=StrongPassword123!
ADMIN_NAME=Admin
